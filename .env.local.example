# ─────────────────────────────────────────────────────────
# .env.local.example — WEB-COMMAND-HQ
# Copy to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real keys.
# ─────────────────────────────────────────────────────────

# ── CLAUDE API ────────────────────────────────────────────
# Get from platform.claude.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model selection — swap here without code changes
# Canonical IDs: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── NOTION ───────────────────────────────────────────────
# Integration token from notion.so/my-integrations
NOTION_API_KEY=secret_...

# Database IDs (from Notion page URL)
NOTION_CLIENT_FEEDBACK_DB_ID=your-database-id-here

# ── WHATSAPP BUSINESS API ────────────────────────────────
# From Meta Developer Portal → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_RECIPIENT=8801719300849

# Webhook verification token — set this in Meta Developer Portal too
WHATSAPP_VERIFY_TOKEN=INSPIRON_TECH_STRIKE_2026

# ── AUDIT VAULT ──────────────────────────────────────────
# Cookie value required to access /audit-vault
# Generate a strong random string: openssl rand -hex 32
AUDIT_TOKEN=your-strong-random-token-here
